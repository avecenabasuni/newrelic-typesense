{
  "name": "Typesense Monitoring",
  "description": "Typesense search engine monitoring dashboard via New Relic Flex. All fields verified with nri-flex 1.17.2. Replace accountId 0 with your New Relic Account ID before importing.",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Overview",
      "description": "Summary of Typesense health and performance",
      "widgets": [
        {
          "title": "",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 12,
            "height": 2
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "# Typesense Monitoring\n---\nThis dashboard monitors the Typesense search engine using New Relic Flex. Data is collected from the `/health`, `/stats.json`, and `/metrics.json` endpoints every 60 seconds.\n\n**Replace `accountId: 0`** throughout this JSON with your New Relic Account ID before importing. | [Typesense Docs](https://typesense.org/docs/) | [New Relic Flex Docs](https://docs.newrelic.com/docs/infrastructure/host-integrations/host-integrations-list/flex-integration-tool-build-your-own-integration/)"
          }
        },
        {
          "title": "Node Health",
          "layout": {
            "column": 1,
            "row": 3,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT filter(count(*), WHERE ok = 'true') AS 'Healthy', filter(count(*), WHERE ok = 'false') AS 'Failed' FROM TypesenseHealthSample SINCE 5 minutes ago"
              }
            ],
            "thresholds": [
              {
                "alertSeverity": "CRITICAL",
                "value": 0
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "Total Requests / sec",
          "layout": {
            "column": 3,
            "row": 3,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(total_requests_per_second) AS 'Total Req/sec' FROM TypesenseStatsSample SINCE 5 minutes ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "Search Requests / sec",
          "layout": {
            "column": 5,
            "row": 3,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(search_requests_per_second) AS 'Search Req/sec' FROM TypesenseStatsSample SINCE 5 minutes ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "Search Latency (ms)",
          "layout": {
            "column": 7,
            "row": 3,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(search_latency_ms) AS 'Avg Search Latency (ms)' FROM TypesenseStatsSample SINCE 5 minutes ago"
              }
